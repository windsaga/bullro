# NVIDIA API (DeepSeek V4 Pro + GLM-5.1)
NVIDIA_API_KEY=nvapi-
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Anthropic API (Claude fallback — NVIDIA 429 소진 시 자동 전환)
ANTHROPIC_API_KEY=sk-ant-

# GitHub (소스 수집용)
GITHUB_TOKEN=

# YouTube Data API v3 (선택 — 없으면 YouTube 수집 건너뜀)
# https://console.cloud.google.com 에서 "YouTube Data API v3" 활성화 후 API 키 발급
YOUTUBE_API_KEY=

# WordPress REST API
WORDPRESS_URL=https://your-blog.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_DEFAULT_CATEGORY_ID=1

# Slack Incoming Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#blog-review

# Reddit (선택 — praw 자동 투고)
# https://www.reddit.com/prefs/apps 에서 "script" 앱 생성
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=bullro-bot/1.0
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_SUBREDDIT=LocalLLaMA
AUTO_POST_REDDIT=false   # true로 변경 시 자동 투고

# Twitter/X (선택 — tweepy 자동 투고)
# https://developer.twitter.com 에서 앱 생성 (Free tier 가능)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
AUTO_POST_TWITTER=false  # true로 변경 시 자동 투고

# WordPress 시리즈 카테고리 ID (WordPress에서 카테고리 생성 후 ID 입력, 0이면 비활성화)
WORDPRESS_CATEGORY_LOCAL_LLM=0
WORDPRESS_CATEGORY_AI_DEVTOOLS=0
WORDPRESS_CATEGORY_AI_AUTOMATION=0

# Semantic Scholar (선택)
SEMANTIC_SCHOLAR_API_KEY=

# 파이프라인 설정
DAILY_POST_COUNT=2
AUTO_PUBLISH=true
SIMILARITY_THRESHOLD=0.75
MIN_QUALITY_SCORE=75  # 0으로 설정하면 품질 게이트 무시하고 무조건 발행
BASE_DIR=/app